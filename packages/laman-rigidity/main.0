// Laman Rigidity Proof — 12 neighbors guarantee fleet rigidity
//
// Laman's theorem (1970): A graph with n vertices in 2D is
// generically rigid if it has exactly 2n - 2 edges and every
// subset of n' vertices spans at most 2n' - 3 edges.
//
// With 12 neighbors per agent in an undirected fleet:
//   edges = n * 12 / 2 = 6n
//   needed = 2n - 2
//   6n >= 2n - 2 for all n >= 1
//
// Therefore: 12-neighbor fleets are ALWAYS rigid.

fun edges_have(n: u32, neighbors: u32) -> u32 {
    return n * neighbors / 2
}

fun edges_needed(n: u32) -> u32 {
    return 2 * n - 2
}

pub fun main(world: World) -> Void raises {
    let neighbors: u32 = 12
    let mut n: u32 = 3
    let mut all_rigid: Bool = true

    while n <= 100 {
        let have = edges_have(n, neighbors)
        let need = edges_needed(n)
        if have < need {
            all_rigid = false
        }
        n = n + 1
    }

    if all_rigid {
        check world.out.write("laman rigidity: all fleet sizes 3-100 are rigid with 12 neighbors\n")
    } else {
        check world.out.write("rigidity failure detected\n")
    }
}
